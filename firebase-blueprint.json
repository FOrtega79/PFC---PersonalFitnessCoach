{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with onboarding metrics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "activityLevel": { "type": "string" },
        "trainingDays": { "type": "number" },
        "primaryGoal": { "type": "string" },
        "bmi": { "type": "number" },
        "bmr": { "type": "number" },
        "tdee": { "type": "number" },
        "startingStatus": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    }
  }
}
